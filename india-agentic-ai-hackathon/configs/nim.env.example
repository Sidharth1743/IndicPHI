# Copy values into repo-root `.env` (gitignored) or export in the shell.

# --- Sarvam API (S4 generator: sarvam-105b) ---
# Context window: 128k. Pipeline uses max_tokens=16384 (quality-safe; not 128k).
# Keep reasoning OFF (reasoning_effort: null).
# Sarvam-105B Business: 120 req/min (ms-llm default tier 1000 RPM is separate).
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai/v1

# --- Azure Foundry / Grok-4.3 (S5 linguistic judge) ---
# OpenAI-compatible chat completions (NOT the /responses URL).
# Auth: Authorization: Bearer $AZURE_FOUNDRY_API_KEY
# Model id: grok-4.3
# Limits (this account): 500 RPM, 500000 TPM
AZURE_FOUNDRY_API_KEY=
# If your .env still uses the typo spelling, pipeline lists it as an explicit fallback.
# AZURE_FOUNDARY_API_KEY=
AZURE_FOUNDRY_CHAT_BASE_URL=https://ambedkar-interpreter-resource.services.ai.azure.com/openai/v1

# --- NVIDIA NIM (optional later; explicit provider switch) ---
NVIDIA_API_KEY=
NIM_BASE_URL=
GENERATOR_MODEL_ID=
JUDGE_MODEL_ID=
